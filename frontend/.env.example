# Frontend — variables de entorno (Vite)
# Copiar a `.env` o `.env.local` según necesidad.

# URL base del API NestJS (debe coincidir con los mocks E2E si usas `page.route` sobre el mismo host).
VITE_API_URL=http://localhost:3000

# Playwright (opcional, al ejecutar `npx playwright test` desde esta carpeta)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
# PW_HEADED=1
